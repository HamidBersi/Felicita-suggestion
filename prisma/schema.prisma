generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Suggestion {
  id          String   @id @default(cuid())
  title       String
  description String?
  price       String
  label       String?
  labelColor  String   @default("orange")
  position    Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
